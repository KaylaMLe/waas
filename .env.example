# Required Variables
RESUME_PATH="Path to your resume PDF"

# API Key (can also be set as system environment variable)
OPENAI_API_KEY="your_openai_api_key_here"

# Optional Variables
SEARCH_URL="https://www.workatastartup.com/companies?..."
APPLIED="Comma-separated list of companies you've already applied to"
SCROLL_COUNT="5"
LOG_LEVEL="info"

# WAAS SQLite database (jobs, companies, applications). Set SKIP_WAAS_DB=1 to disable and use APPLIED only.
# WAAS_DB_PATH=".waas-data/waas.db"
# SKIP_WAAS_DB="0"
RUN_MODE="live"
# RUN_MODE="stored"
COOLDOWN_MONTHS="6"
STALE_LINK_DAYS="2"
COMPANY_BLOCK_RECENT_HOURS="24"

# AI Model Configuration (all default to gpt-4o-mini)
APP_METHOD_MODEL="gpt-4o-mini"
JOB_COMPARE_MODEL="gpt-4o-mini"
APP_MESSAGE_MODEL="gpt-4o-mini" 